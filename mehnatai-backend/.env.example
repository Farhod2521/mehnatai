# Copy to .env and fill in real values

# App
DEBUG=false

# PostgreSQL
POSTGRES_USER=mehnatai
POSTGRES_PASSWORD=mehnatai_secret
POSTGRES_DB=mehnatai_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# JWT — CHANGE THIS IN PRODUCTION!
SECRET_KEY=mehnatai-super-secret-jwt-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
